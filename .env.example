# 각자 알아서 키 발급 받아서 채우기
# .env.example 참고해서 .env 만들기

# ==========================
# API Keys
# ==========================

OPENAI_API_KEY=your_openai_api_key # 무시
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key

# ==========================
# Model Names
# ==========================

OPENAI_MODEL= # 무시
CLAUDE_MODEL=claude-sonnet-4
GEMINI_MODEL=gemini-3.1-flash-lite


# ==========================
# LLM Parameters
# ==========================

TEMPERATURE=0.3
MAX_TOKENS=1000

# ==========================
# Application
# ==========================

APP_ENV=development
LOG_LEVEL=INFO